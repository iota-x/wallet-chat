# ── Model credential (pick ONE) ──────────────────────────────────────────────
# The agent picks a provider by which key is present (free keys take precedence).
#
# Option A — Vercel AI Gateway → model "anthropic/claude-opus-4-8" (the showcase
# target). Requires a credit card on file. Get a key at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=
#
# Option B — Google Gemini (FREE, no card). Key: https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash
#
# Option C — Groq (FREE, no card). Key: https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Solana RPC endpoints. Public endpoints work but are rate-limited; a Helius/
# Triton/QuickNode URL is strongly recommended for reliable simulation.
NEXT_PUBLIC_DEVNET_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Ethereum RPCs. MUST support eth_simulateV1 (publicnode defaults do; Alchemy/Infura work too).
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_ETH_MAINNET_RPC=https://ethereum-rpc.publicnode.com

# Default mode the UI boots into: "devnet" (the executable test tier for the active chain:
# Solana devnet / Ethereum Sepolia / Bitcoin testnet) or "mainnet" (real, read-only, signing off).
NEXT_PUBLIC_DEFAULT_MODE=devnet
