# Vercel AI Gateway key — routes model string "anthropic/claude-opus-4-8".
# Get one at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=

# Solana RPC endpoints. Public endpoints work but are rate-limited; a Helius/
# Triton/QuickNode URL is strongly recommended for reliable simulation.
NEXT_PUBLIC_DEVNET_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Default mode the UI boots into: "devnet" (executes end-to-end) or
# "mainnet" (read-only: real reads/plan/sim, signing disabled).
NEXT_PUBLIC_DEFAULT_MODE=devnet
